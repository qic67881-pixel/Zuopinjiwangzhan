{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "tag": { "type": "string" },
        "gradient": { "type": "string" },
        "mediaItems": {
          "type": "array",
          "items": { "$ref": "MediaItem" }
        },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "category", "tag"]
    },
    "MediaItem": {
      "title": "MediaItem",
      "description": "An image or video file item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] }
      },
      "required": ["id", "url", "type"]
    },
    "PageContent": {
      "title": "PageContent",
      "description": "Static page content for About, Archive, Contact",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mediaItems": {
          "type": "array",
          "items": { "$ref": "MediaItem" }
        }
      },
      "required": ["title", "content"]
    },
    "ThemeSettings": {
      "title": "ThemeSettings",
      "description": "Visual customization settings",
      "type": "object",
      "properties": {
        "backgroundColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "logoColor": { "type": "string" },
        "nameColor": { "type": "string" },
        "projectTitleColor": { "type": "string" },
        "textColor": { "type": "string" },
        "categoryColor": { "type": "string" },
        "categoryActiveColor": { "type": "string" },
        "backgroundImageUrl": { "type": ["string", "null"] },
        "backgroundOpacity": { "type": "number" },
        "backgroundBlur": { "type": "number" },
        "layout": { "type": "string", "enum": ["sidebar-left", "sidebar-right", "top-nav"] },
        "cardStyle": { "type": "string", "enum": ["minimal", "glass", "bordered"] }
      }
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global settings including website name and categories",
      "type": "object",
      "properties": {
        "websiteName": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string" },
        "userBio": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"] },
        "categories": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects list"
    },
    "/pages/{pageId}": {
      "schema": "PageContent",
      "description": "Static pages (about, archive, contact)"
    },
    "/settings/theme": {
      "schema": "ThemeSettings",
      "description": "Global visual settings"
    },
    "/settings/config": {
      "schema": "AppConfig",
      "description": "Global app configuration and profile info"
    }
  }
}
